# Twitch app credentials (Twitch Developer Console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Comma-separated broadcaster user IDs to track (recommended)
# Example: 141981764,12826
BROADCASTER_IDS=

# Optional: if you prefer logins instead of IDs, set this and leave BROADCASTER_IDS empty.
# Example: shroud,ninja
BROADCASTER_LOGINS=

# HTTP server
PORT=3000
